//
//  GEIST TOTEM - Magic Sturdy port from Cheapino QMK keymap.c
//  Generated by ChatGPT from the two uploaded files.
//  Notes:
//  - Extra left pinky = ESC
//  - Extra right pinky = ENTER
//  - Esc combos and right-hand Enter combo removed
//  - Left-hand Enter combo preserved
//  - QMK adaptive Magic is emulated with sticky context layers and macros
//  - Exact QMK custom timing for DF_REPEAT / DF_BSPC cannot be 1:1 in keymap-only ZMK
//

#include <behaviors.dtsi>
#include <dt-bindings/zmk/keys.h>
#include <dt-bindings/zmk/bt.h>
#include <dt-bindings/zmk/outputs.h>

#define BASE   0
#define NAV    1
#define SYM    2
#define FLIP   3
#define ADJ    4
#define TVP1   5
#define TVP2   6
#define MG_A   7
#define MG_C   8
#define MG_D   9
#define MG_E   10
#define MG_F   11
#define MG_G   12
#define MG_J   13
#define MG_K   14
#define MG_L   15
#define MG_N   16
#define MG_O   17
#define MG_P   18
#define MG_Q   19
#define MG_R   20
#define MG_S   21
#define MG_T   22
#define MG_U   23
#define MG_V   24
#define MG_W   25
#define MG_Y   26

&mt {
  quick-tap-ms = <100>;
  global-quick-tap;
  flavor = "tap-preferred";
  tapping-term-ms = <200>;
};

&lt {
  quick-tap-ms = <100>;
  flavor = "tap-preferred";
  tapping-term-ms = <200>;
};

&sl {
  release-after-ms = <1000>;
};

/ {
    behaviors {
        rep: repeat_tap_passthrough {
            compatible = "zmk,behavior-macro-one-param";
            #binding-cells = <1>;
            bindings = <&key_repeat>;
        };

        ralt_rep: ralt_repeat {
            compatible = "zmk,behavior-hold-tap";
            #binding-cells = <2>;
            flavor = "tap-preferred";
            tapping-term-ms = <200>;
            quick-tap-ms = <100>;
            bindings = <&kp>, <&rep>;
        };

        bspc_rsft: backspace_right_shift {
            compatible = "zmk,behavior-hold-tap";
            #binding-cells = <2>;
            flavor = "hold-preferred";
            tapping-term-ms = <200>;
            quick-tap-ms = <200>;
            bindings = <&kp>, <&kp>;
        };

        sym_cbspc: sym_ctrl_backspace {
            compatible = "zmk,behavior-hold-tap";
            #binding-cells = <2>;
            flavor = "hold-preferred";
            tapping-term-ms = <200>;
            quick-tap-ms = <200>;
            bindings = <&mo>, <&kp>;
        };

        hmt_s: hold_tap_s {
            compatible = "zmk,behavior-hold-tap";
            #binding-cells = <2>;
            flavor = "tap-preferred";
            tapping-term-ms = <200>;
            quick-tap-ms = <100>;
            bindings = <&kp>, <&m_s>;
        };

        hmt_t: hold_tap_t {
            compatible = "zmk,behavior-hold-tap";
            #binding-cells = <2>;
            flavor = "tap-preferred";
            tapping-term-ms = <200>;
            quick-tap-ms = <100>;
            bindings = <&kp>, <&m_t>;
        };

        hmt_r: hold_tap_r {
            compatible = "zmk,behavior-hold-tap";
            #binding-cells = <2>;
            flavor = "tap-preferred";
            tapping-term-ms = <200>;
            quick-tap-ms = <100>;
            bindings = <&kp>, <&m_r>;
        };

        hmt_d: hold_tap_d {
            compatible = "zmk,behavior-hold-tap";
            #binding-cells = <2>;
            flavor = "tap-preferred";
            tapping-term-ms = <200>;
            quick-tap-ms = <100>;
            bindings = <&kp>, <&m_d>;
        };

        hmt_k: hold_tap_k {
            compatible = "zmk,behavior-hold-tap";
            #binding-cells = <2>;
            flavor = "tap-preferred";
            tapping-term-ms = <200>;
            quick-tap-ms = <100>;
            bindings = <&kp>, <&m_k>;
        };

        hmt_j: hold_tap_j {
            compatible = "zmk,behavior-hold-tap";
            #binding-cells = <2>;
            flavor = "tap-preferred";
            tapping-term-ms = <200>;
            quick-tap-ms = <100>;
            bindings = <&kp>, <&m_j>;
        };

        hmt_g: hold_tap_g {
            compatible = "zmk,behavior-hold-tap";
            #binding-cells = <2>;
            flavor = "tap-preferred";
            tapping-term-ms = <200>;
            quick-tap-ms = <100>;
            bindings = <&kp>, <&m_g>;
        };

        hmt_n: hold_tap_n {
            compatible = "zmk,behavior-hold-tap";
            #binding-cells = <2>;
            flavor = "tap-preferred";
            tapping-term-ms = <200>;
            quick-tap-ms = <100>;
            bindings = <&kp>, <&m_n>;
        };

        hmt_e: hold_tap_e {
            compatible = "zmk,behavior-hold-tap";
            #binding-cells = <2>;
            flavor = "tap-preferred";
            tapping-term-ms = <200>;
            quick-tap-ms = <100>;
            bindings = <&kp>, <&m_e>;
        };

        hmt_a: hold_tap_a {
            compatible = "zmk,behavior-hold-tap";
            #binding-cells = <2>;
            flavor = "tap-preferred";
            tapping-term-ms = <200>;
            quick-tap-ms = <100>;
            bindings = <&kp>, <&m_a>;
        };

    };

    combos {
        compatible = "zmk,combos";
        combo_bspc_n {
            timeout-ms = <50>;
            key-positions = <16 36>;
            bindings = <&kp SQT>;
        };
        combo_bspc_e {
            timeout-ms = <50>;
            key-positions = <17 36>;
            bindings = <&kp MINUS>;
        };
        combo_bspc_a {
            timeout-ms = <50>;
            key-positions = <18 36>;
            bindings = <&kp SEMI>;
        };
        combo_bspc_comm {
            timeout-ms = <50>;
            key-positions = <28 36>;
            bindings = <&kp LT>;
        };
        combo_bspc_dot {
            timeout-ms = <50>;
            key-positions = <29 36>;
            bindings = <&kp GT>;
        };
        combo_bspc_sqt {
            timeout-ms = <50>;
            key-positions = <30 36>;
            bindings = <&kp FSLH>;
        };

        combo_mag2_n {
            timeout-ms = <50>;
            key-positions = <16 35>;
            bindings = <&kp DQT>;
        };
        combo_mag2_e {
            timeout-ms = <50>;
            key-positions = <17 35>;
            bindings = <&kp UNDER>;
        };
        combo_mag2_a {
            timeout-ms = <50>;
            key-positions = <18 35>;
            bindings = <&kp COLON>;
        };
        combo_mag2_comm {
            timeout-ms = <50>;
            key-positions = <28 35>;
            bindings = <&kp EXCL>;
        };
        combo_mag2_dot {
            timeout-ms = <50>;
            key-positions = <29 35>;
            bindings = <&kp QUESTION>;
        };
        combo_mag2_sqt {
            timeout-ms = <50>;
            key-positions = <30 35>;
            bindings = <&kp BSLH>;
        };

        combo_enter_left {
            timeout-ms = <50>;
            key-positions = <22 23>;
            bindings = <&kp RET>;
        };
        combo_delete_left {
            timeout-ms = <50>;
            key-positions = <21 22>;
            bindings = <&kp DEL>;
        };
        combo_delete_right {
            timeout-ms = <50>;
            key-positions = <29 30>;
            bindings = <&kp DEL>;
        };
        combo_bspc_left {
            timeout-ms = <50>;
            key-positions = <23 24>;
            bindings = <&kp BSPC>;
        };
        combo_tvp {
            timeout-ms = <100>;
            key-positions = <11 12 13>;
            bindings = <&tog TVP1>;
        };
    };

    macros {
        m_a: magic_context_a {
            compatible = "zmk,behavior-macro-one-param";
            #binding-cells = <1>;
            wait-ms = <0>;
            tap-ms = <5>;
            bindings
                = <&macro_tap &kp A>
                , <&macro_tap &sl MG_A>
                ;
        };

        m_c: magic_context_c {
            compatible = "zmk,behavior-macro-one-param";
            #binding-cells = <1>;
            wait-ms = <0>;
            tap-ms = <5>;
            bindings
                = <&macro_tap &kp C>
                , <&macro_tap &sl MG_C>
                ;
        };

        m_d: magic_context_d {
            compatible = "zmk,behavior-macro-one-param";
            #binding-cells = <1>;
            wait-ms = <0>;
            tap-ms = <5>;
            bindings
                = <&macro_tap &kp D>
                , <&macro_tap &sl MG_D>
                ;
        };

        m_e: magic_context_e {
            compatible = "zmk,behavior-macro-one-param";
            #binding-cells = <1>;
            wait-ms = <0>;
            tap-ms = <5>;
            bindings
                = <&macro_tap &kp E>
                , <&macro_tap &sl MG_E>
                ;
        };

        m_f: magic_context_f {
            compatible = "zmk,behavior-macro-one-param";
            #binding-cells = <1>;
            wait-ms = <0>;
            tap-ms = <5>;
            bindings
                = <&macro_tap &kp F>
                , <&macro_tap &sl MG_F>
                ;
        };

        m_g: magic_context_g {
            compatible = "zmk,behavior-macro-one-param";
            #binding-cells = <1>;
            wait-ms = <0>;
            tap-ms = <5>;
            bindings
                = <&macro_tap &kp G>
                , <&macro_tap &sl MG_G>
                ;
        };

        m_j: magic_context_j {
            compatible = "zmk,behavior-macro-one-param";
            #binding-cells = <1>;
            wait-ms = <0>;
            tap-ms = <5>;
            bindings
                = <&macro_tap &kp J>
                , <&macro_tap &sl MG_J>
                ;
        };

        m_k: magic_context_k {
            compatible = "zmk,behavior-macro-one-param";
            #binding-cells = <1>;
            wait-ms = <0>;
            tap-ms = <5>;
            bindings
                = <&macro_tap &kp K>
                , <&macro_tap &sl MG_K>
                ;
        };

        m_l: magic_context_l {
            compatible = "zmk,behavior-macro-one-param";
            #binding-cells = <1>;
            wait-ms = <0>;
            tap-ms = <5>;
            bindings
                = <&macro_tap &kp L>
                , <&macro_tap &sl MG_L>
                ;
        };

        m_n: magic_context_n {
            compatible = "zmk,behavior-macro-one-param";
            #binding-cells = <1>;
            wait-ms = <0>;
            tap-ms = <5>;
            bindings
                = <&macro_tap &kp N>
                , <&macro_tap &sl MG_N>
                ;
        };

        m_o: magic_context_o {
            compatible = "zmk,behavior-macro-one-param";
            #binding-cells = <1>;
            wait-ms = <0>;
            tap-ms = <5>;
            bindings
                = <&macro_tap &kp O>
                , <&macro_tap &sl MG_O>
                ;
        };

        m_p: magic_context_p {
            compatible = "zmk,behavior-macro-one-param";
            #binding-cells = <1>;
            wait-ms = <0>;
            tap-ms = <5>;
            bindings
                = <&macro_tap &kp P>
                , <&macro_tap &sl MG_P>
                ;
        };

        m_q: magic_context_q {
            compatible = "zmk,behavior-macro-one-param";
            #binding-cells = <1>;
            wait-ms = <0>;
            tap-ms = <5>;
            bindings
                = <&macro_tap &kp Q>
                , <&macro_tap &sl MG_Q>
                ;
        };

        m_r: magic_context_r {
            compatible = "zmk,behavior-macro-one-param";
            #binding-cells = <1>;
            wait-ms = <0>;
            tap-ms = <5>;
            bindings
                = <&macro_tap &kp R>
                , <&macro_tap &sl MG_R>
                ;
        };

        m_s: magic_context_s {
            compatible = "zmk,behavior-macro-one-param";
            #binding-cells = <1>;
            wait-ms = <0>;
            tap-ms = <5>;
            bindings
                = <&macro_tap &kp S>
                , <&macro_tap &sl MG_S>
                ;
        };

        m_t: magic_context_t {
            compatible = "zmk,behavior-macro-one-param";
            #binding-cells = <1>;
            wait-ms = <0>;
            tap-ms = <5>;
            bindings
                = <&macro_tap &kp T>
                , <&macro_tap &sl MG_T>
                ;
        };

        m_u: magic_context_u {
            compatible = "zmk,behavior-macro-one-param";
            #binding-cells = <1>;
            wait-ms = <0>;
            tap-ms = <5>;
            bindings
                = <&macro_tap &kp U>
                , <&macro_tap &sl MG_U>
                ;
        };

        m_v: magic_context_v {
            compatible = "zmk,behavior-macro-one-param";
            #binding-cells = <1>;
            wait-ms = <0>;
            tap-ms = <5>;
            bindings
                = <&macro_tap &kp V>
                , <&macro_tap &sl MG_V>
                ;
        };

        m_w: magic_context_w {
            compatible = "zmk,behavior-macro-one-param";
            #binding-cells = <1>;
            wait-ms = <0>;
            tap-ms = <5>;
            bindings
                = <&macro_tap &kp W>
                , <&macro_tap &sl MG_W>
                ;
        };

        m_y: magic_context_y {
            compatible = "zmk,behavior-macro-one-param";
            #binding-cells = <1>;
            wait-ms = <0>;
            tap-ms = <5>;
            bindings
                = <&macro_tap &kp Y>
                , <&macro_tap &sl MG_Y>
                ;
        };

        gif: gif {
            label = "giphy";
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings
                = <&macro_press &kp LSHFT>
                , <&macro_tap &kp N2>
                , <&macro_release &kp LSHFT>
                , <&macro_tap &kp G &kp I &kp F>
                ;
        };
    };

    keymap {
        compatible = "zmk,keymap";

        base_layer {
            label = "BASE";
            // Magic Sturdy core + extra pinky ESC/ENTER
            bindings = <
                &m_v 0              &kp M               &m_l 0              &m_c 0              &m_p 0              &kp B               &key_repeat         &m_u 0              &m_o 0              &m_q 0
                &hmt_s LGUI 0       &hmt_t LALT 0       &hmt_r LCTRL 0      &hmt_d LSHFT 0      &m_y 0              &m_f 0              &hmt_n RSHFT 0      &hmt_e RCTRL 0      &hmt_a LALT 0       &mt RGUI I
                &kp ESC             &mt LSHFT X         &hmt_k LCTRL 0      &hmt_j LALT 0       &hmt_g LGUI 0       &m_w 0              &kp Z               &mt RGUI H          &mt LALT COMMA      &mt RCTRL DOT       &mt RSHFT SQT       &kp RET
                &sym_cbspc SYM LC(BSPC)  &lt NAV SPACE       &lt FLIP TAB        &key_repeat         &bspc_rsft RSHFT BSPC  &ralt_rep RALT 0
            >;
        };

        nav_layer {
            label = "NAV";
            bindings = <
                &kp PSCRN           &kp HOME            &kp UP              &kp END             &kp PG_UP           &kp EQUAL           &kp KP_N7           &kp KP_N8           &kp KP_N9           &kp KP_PLUS
                &kp FSLH            &kp LEFT            &kp DOWN            &kp RIGHT           &kp PG_DN           &kp EXCL            &kp KP_N4           &kp KP_N5           &kp KP_N6           &kp KP_MINUS
                &trans              &kp BSLH            &kp LBRC            &kp LBKT            &kp RBKT            &kp RBRC            &kp QUESTION        &kp KP_N1           &kp KP_N2           &kp KP_N3           &kp PIPE            &trans
                &trans              &trans              &trans              &kp LPAR            &kp KP_N0           &kp RPAR
            >;
        };

        sym_layer {
            label = "SYM";
            bindings = <
                &kp GRAVE           &kp AT              &kp HASH            &kp DLLR            &kp PRCNT           &kp CARET           &kp AMPS            &kp LS(N8)           &kp EQUAL           &kp TILDE
                &kp N1              &kp N2              &kp N3              &kp N4              &kp N5              &kp N6              &kp N7              &kp N8              &kp N9              &kp N0
                &trans              &kp F1              &kp F2              &kp F3              &kp F4              &kp F5              &kp F6              &kp F7              &kp F8              &kp F9              &kp F10             &trans
                &trans              &trans              &trans              &trans              &kp F11             &kp F12
            >;
        };

        flip_layer {
            label = "FLIP";
            // Mostly copied from Cheapino FLIP; adaptive Magic at this left-hand position falls back to repeat in keymap-only ZMK
            bindings = <
                &m_q 0              &m_o 0              &m_u 0              &key_repeat         &kp B               &kp INS             &kp CAPS            &kp KP_NUM          &kp SLCK            &kp PAUSE_BREAK
                &mt RGUI I          &hmt_a LALT 0       &hmt_e RCTRL 0      &hmt_n RSHFT 0      &m_f 0              &trans              &trans              &trans              &trans              &trans
                &trans              &mt RSHFT SQT       &mt RCTRL DOT       &mt LALT COMMA      &mt RGUI H          &kp Z               &trans              &trans              &trans              &trans              &trans              &trans
                &trans              &trans              &trans              &trans              &trans              &trans
            >;
        };

        adjust_layer {
            label = "ADJ";
            bindings = <
                &sys_reset          &bt BT_CLR          &out OUT_TOG        &trans              &trans              &trans              &kp F7              &kp F8              &kp F9              &kp F12
                &bootloader         &bt BT_NXT          &trans              &trans              &trans              &trans              &kp F4              &kp F5              &kp F6              &kp F11
                &trans              &trans              &bt BT_PRV          &trans              &trans              &trans              &trans              &kp F1              &kp F2              &kp F3              &kp F10             &trans
                &trans              &trans              &trans              &trans              &trans              &trans
            >;
        };

        tvp1_layer {
            label = "TVP 1";
            // Preserved from old Totem file
            bindings = <
                &kp TAB             &kp I               &kp LC(LALT)        &kp O               &kp LC(F20)         &none               &none               &none               &none               &none
                &lt TVP2 L          &kp LEFT            &kp LALT            &kp RIGHT           &kp SPACE           &none               &none               &none               &none               &none
                &kp J               &kp LSHFT           &kp LC(C)           &kp BSPC            &kp LC(V)           &kp LC(F19)         &none               &none               &none               &none               &none               &none
                &trans              &kp LC(F14)         &kp LC(F13)         &none               &none               &none
            >;
        };

        tvp2_layer {
            label = "TVP 2";
            // Preserved from old Totem file
            bindings = <
                &kp LC(F18)         &kp LS(I)           &kp LS(HOME)        &kp LS(O)           &kp LS(F)           &trans              &kp F7              &kp F8              &kp F9              &kp F12
                &trans              &kp LS(LEFT)        &kp LC(F17)         &kp LS(RIGHT)       &kp RET             &trans              &kp F4              &kp F5              &kp F6              &kp F11
                &trans              &kp J               &kp LS(C)           &kp LC(F16)         &kp LS(V)           &kp LC(F15)         &trans              &kp F1              &kp F2              &kp F3              &kp F10             &trans
                &trans              &kp LC(F12)         &kp LC(F11)         &trans              &trans              &trans
            >;
        };

        magic_a_layer {
            label = "MG_A";
            // After A: Magic_1 -> O, Magic_2 -> DOT
            bindings = <
                &trans              &trans              &trans              &trans              &trans              &trans              &m_o 0              &trans              &trans              &trans
                &trans              &trans              &trans              &trans              &trans              &trans              &trans              &trans              &trans              &trans
                &trans              &trans              &trans              &trans              &trans              &trans              &trans              &trans              &trans              &trans              &trans              &trans
                &trans              &trans              &trans              &kp DOT             &trans              &trans
            >;
        };

        magic_c_layer {
            label = "MG_C";
            // After C: Magic_1 -> K, Magic_2 -> Y
            bindings = <
                &trans              &trans              &trans              &trans              &trans              &trans              &m_k 0              &trans              &trans              &trans
                &trans              &trans              &trans              &trans              &trans              &trans              &trans              &trans              &trans              &trans
                &trans              &trans              &trans              &trans              &trans              &trans              &trans              &trans              &trans              &trans              &trans              &trans
                &trans              &trans              &trans              &m_y 0              &trans              &trans
            >;
        };

        magic_d_layer {
            label = "MG_D";
            // After D: Magic_1 -> Y, Magic_2 -> G
            bindings = <
                &trans              &trans              &trans              &trans              &trans              &trans              &m_y 0              &trans              &trans              &trans
                &trans              &trans              &trans              &trans              &trans              &trans              &trans              &trans              &trans              &trans
                &trans              &trans              &trans              &trans              &trans              &trans              &trans              &trans              &trans              &trans              &trans              &trans
                &trans              &trans              &trans              &m_g 0              &trans              &trans
            >;
        };

        magic_e_layer {
            label = "MG_E";
            // After E: Magic_1 -> U, Magic_2 -> COMMA
            bindings = <
                &trans              &trans              &trans              &trans              &trans              &trans              &m_u 0              &trans              &trans              &trans
                &trans              &trans              &trans              &trans              &trans              &trans              &trans              &trans              &trans              &trans
                &trans              &trans              &trans              &trans              &trans              &trans              &trans              &trans              &trans              &trans              &trans              &trans
                &trans              &trans              &trans              &kp COMMA           &trans              &trans
            >;
        };

        magic_f_layer {
            label = "MG_F";
            // After F: Magic_1 -> repeat, Magic_2 -> N
            bindings = <
                &trans              &trans              &trans              &trans              &trans              &trans              &key_repeat         &trans              &trans              &trans
                &trans              &trans              &trans              &trans              &trans              &trans              &trans              &trans              &trans              &trans
                &trans              &trans              &trans              &trans              &trans              &trans              &trans              &trans              &trans              &trans              &trans              &trans
                &trans              &trans              &trans              &m_n 0              &trans              &trans
            >;
        };

        magic_g_layer {
            label = "MG_G";
            // After G: Magic_1 -> Y, Magic_2 -> D
            bindings = <
                &trans              &trans              &trans              &trans              &trans              &trans              &m_y 0              &trans              &trans              &trans
                &trans              &trans              &trans              &trans              &trans              &trans              &trans              &trans              &trans              &trans
                &trans              &trans              &trans              &trans              &trans              &trans              &trans              &trans              &trans              &trans              &trans              &trans
                &trans              &trans              &trans              &m_d 0              &trans              &trans
            >;
        };

        magic_j_layer {
            label = "MG_J";
            // After J: Magic_1 -> M, Magic_2 -> repeat
            bindings = <
                &trans              &trans              &trans              &trans              &trans              &trans              &kp M               &trans              &trans              &trans
                &trans              &trans              &trans              &trans              &trans              &trans              &trans              &trans              &trans              &trans
                &trans              &trans              &trans              &trans              &trans              &trans              &trans              &trans              &trans              &trans              &trans              &trans
                &trans              &trans              &trans              &key_repeat         &trans              &trans
            >;
        };

        magic_k_layer {
            label = "MG_K";
            // After K: Magic_1 -> S, Magic_2 -> repeat
            bindings = <
                &trans              &trans              &trans              &trans              &trans              &trans              &m_s 0              &trans              &trans              &trans
                &trans              &trans              &trans              &trans              &trans              &trans              &trans              &trans              &trans              &trans
                &trans              &trans              &trans              &trans              &trans              &trans              &trans              &trans              &trans              &trans              &trans              &trans
                &trans              &trans              &trans              &key_repeat         &trans              &trans
            >;
        };

        magic_l_layer {
            label = "MG_L";
            // After L: Magic_1 -> K, Magic_2 -> R
            bindings = <
                &trans              &trans              &trans              &trans              &trans              &trans              &m_k 0              &trans              &trans              &trans
